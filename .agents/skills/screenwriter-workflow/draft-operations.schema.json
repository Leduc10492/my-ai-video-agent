{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-director.local/schemas/draft-operations.schema.json",
  "title": "AI Director candidate operations",
  "type": "object",
  "additionalProperties": false,
  "required": ["summary", "operations"],
  "properties": {
    "summary": { "type": "string", "minLength": 1 },
    "operations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["op", "entityType", "entityId", "baseRevision", "payload"],
        "properties": {
          "op": { "enum": ["create", "patch", "reorder", "link", "unlink", "archive"] },
          "entityType": {
            "enum": [
              "project", "episode", "act", "sequence", "scene", "beat",
              "scriptBlock", "asset", "assetUsage", "referenceState", "draftImage",
              "shotRow", "promptEnvelope", "shotEnvelopeLink", "task", "qaFinding"
            ]
          },
          "entityId": { "type": ["string", "null"] },
          "baseRevision": { "type": ["string", "null"] },
          "payload": { "type": "string", "description": "JSON-encoded operation payload" }
        }
      }
    }
  }
}
